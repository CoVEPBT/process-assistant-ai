# Process Assistant AI — environment variables
# Copy this file to .env and fill in the real values. NEVER commit .env.

# OpenAI API key — get from platform.openai.com -> API keys
OPENAI_API_KEY=sk-your-key-here

# Model to use for AI requests. gpt-4o-mini is the cheapest GPT-4-class model
# and works well for process-writing assistance.
OPENAI_MODEL=gpt-4o-mini

# Server port
PORT=3001
